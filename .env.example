# Google Maps (T080)
# Get API key em https://console.cloud.google.com/google/maps-apis/credentials
# Restringir por package name (iOS) e SHA-1 fingerprint (Android)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# EAS (Expo Application Services) para push tokens
# Configure em https://expo.dev/eas
EXPO_PUBLIC_EAS_PROJECT_ID=
